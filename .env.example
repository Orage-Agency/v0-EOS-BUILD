# Supabase
# NEXT_PUBLIC_SUPABASE_URL is preferred; SUPABASE_URL works for server-side
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase renamed "anon key" → "publishable key" in the dashboard; either name works
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key  # alternative Vercel/Supabase naming
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used in invite emails)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Sentry — get DSN from sentry.io > Project Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=orage-core
# SENTRY_AUTH_TOKEN is needed for source map uploads (add to Vercel env, not here)
